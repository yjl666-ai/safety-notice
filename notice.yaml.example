# ─────────────────────────────────────────
# 安全隐患整改通知书 - 输入配置样例
# ─────────────────────────────────────────
# 用法:
#   手动模式: cp 这个为 notice.yaml,自己填字段
#   AI 模式:   ai_suggest.py "隐患描述" 会自动覆盖 notice.yaml

to_unit: "XX项目部"          # ← 手动改
from_unit: "安监部"
issue_date: "2026年7月17日"
doc_number: "安监〔2026〕第XXX号"

location: "施工现场临时用电区域"
context: "日常巡检"

regulation_name: "施工现场临时用电安全技术规范"
regulation_code: "JGJ 46-2005"
regulation_figures: "1"      # 引用规范的图号,留空为 ""

hazard: "电线泡水"
hazard_figures: "2、3"        # 隐患照片图号,留空为 ""

requirements:
  - "立即切断泡水区域电源,拆除受水浸泡的电线,干燥或更换受损线路"
  - "全面排查现场临时用电线路,必须架空敷设或穿管保护,严禁拖地、泡水"
  - "严格执行《施工现场临时用电安全技术规范》(JGJ 46-2005)第7章用电线路相关规定,加强临时用电日常巡检"

deadline_days: 3
penalty_doc: "施工现场奖惩实施细则"
penalty: "违约扣款"

# 可选字段(留空走默认)
review_clause: ""          # 默认: "安监部将于整改完成后组织复查"
feedback_clause: ""         # 默认: "并将整改结果书面报安监部"
